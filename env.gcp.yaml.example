# Env vars NO secretas para Cloud Run (las secretas viven en Secret Manager).
# Copia a env.gcp.yaml y ajusta los valores. Formato YAML plano: KEY: "value".
#
# Los secretos (SLACK_BOT_TOKEN, SLACK_APP_TOKEN, NOTION_TOKEN, ANTHROPIC_API_KEY,
# SMTP_PASSWORD) NO se ponen aquí; se suben con `./deploy-gcp.sh --sync-secrets`.

# --- Modo de ejecución ---
APP_MODE: "produccion"
REGISTRO_WEB_HABILITADO: "false"

# --- Frontend / CORS ---
# En el primer deploy no conoces la URL de Cloud Run todavía. Deja placeholders,
# despliega, coge la URL que imprime el script y re-ejecuta el deploy con los
# valores reales (o mejor: configura un dominio propio desde el principio).
FRONTEND_ORIGIN: "https://TU-SERVICIO-XXXXXX-ew.a.run.app"
APP_PUBLIC_URL: "https://TU-SERVICIO-XXXXXX-ew.a.run.app"
CORS_EXTRA_ORIGINS: ""

# --- Slack (no secreto) ---
SLACK_TEST_USER_ID: ""
SLACK_LISTAS_PENDIENTES_HABILITADO: "false"

# --- Notion (no secreto: son IDs/URLs) ---
NOTION_DATABASE_ID: ""
NOTION_EMPLOYEES_DATABASE_ID: ""
NOTION_PARENT_PAGE_ID: "https://app.notion.com/p/..."
NOTION_USERS_DATABASE_NAME: "Usuarios web"

# --- SMTP (password va como secreto) ---
SMTP_HOST: "smtp.gmail.com"
SMTP_PORT: "587"
SMTP_USER: "tucuenta@igeneris.com"
SMTP_FROM: "tucuenta@igeneris.com"
SMTP_USE_TLS: "true"
