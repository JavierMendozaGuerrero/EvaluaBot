# Qué NO meter en la imagen Docker. Reduce el tamaño y, sobre todo,
# evita filtrar secretos (.env) dentro del contenedor.

# Secretos y configuración local — NUNCA dentro de la imagen.
.env
.env.*
.env_*
!.env.example

# Entornos virtuales de Python
.venv/
venv/
env/

# Cachés y artefactos de Python
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/

# Git
.git/
.gitignore

# Frontend: se compila DENTRO de la imagen (etapa Node del Dockerfile), así que sí
# entra el código fuente, pero nunca sus dependencias ni el build ya generado.
frontend/node_modules/
frontend/dist/

# Archivos generados en local (en producción viven en el bucket de Cloud Storage).
backend/dashboard_web/*
!backend/dashboard_web/.gitkeep

# Configuración de herramientas de desarrollo
.claude/
docs/
*.log
.DS_Store

# El propio Dockerfile y este archivo no hacen falta dentro de la imagen.
Dockerfile
.dockerignore
