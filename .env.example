# ─────────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────────
# URL base de la API que usa el frontend (dejar vacío si frontend y backend corren juntos)
VITE_API_BASE_URL=

# Origen permitido para CORS. Usa localhost si solo accedes desde tu máquina,
# la IP de red (ej. http://10.0.10.16:5173) para acceso desde la oficina,
# o el dominio real en producción (ej. https://evaluaciones.tuempresa.com).
FRONTEND_ORIGIN=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173

# Orígenes CORS adicionales, separados por comas (opcional). Útil en producción si
# el frontend se sirve desde más de un dominio (ej. dominio propio + preview de Vercel).
# Los orígenes de desarrollo (localhost:5173) siempre están permitidos.
CORS_EXTRA_ORIGINS=

# ─────────────────────────────────────────────
# MODO DE EJECUCIÓN
# ─────────────────────────────────────────────
# "prueba" → envía evaluaciones ahora y cada X minutos, solo al SLACK_TEST_USER_ID
# "produccion" → envía según el calendario de Notion, a todos los empleados
APP_MODE=prueba

# Auto-registro web. Desactivado por defecto: las cuentas se crean con
# create_users_from_employees.py. Si lo pones en "true", el alta exige que el email
# esté en la Lista de empleados de Notion y verificación por código enviado al email.
REGISTRO_WEB_HABILITADO=false

# ─────────────────────────────────────────────
# SLACK
# ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Solo necesario en modo prueba: Slack ID del usuario que recibe las evaluaciones de prueba
# Para encontrar tu ID: en Slack → tu perfil → ⋯ → Copiar ID de miembro
SLACK_TEST_USER_ID=

# Lista de "Evaluaciones pendientes" (Slack Lists). Requiere workspace de Slack
# en plan de pago. Déjalo en false hasta migrar al workspace definitivo de la
# empresa; el bot funciona igual sin esto, solo no crea la lista de pendientes.
SLACK_LISTAS_PENDIENTES_HABILITADO=false

# ─────────────────────────────────────────────
# NOTION
# ─────────────────────────────────────────────
NOTION_TOKEN=ntn_...

# ID de la base de datos raíz (opcional si usas NOTION_PARENT_PAGE_ID)
NOTION_DATABASE_ID=

# ID de la BD de empleados (opcional: si no se indica, el bot la busca por nombre)
NOTION_EMPLOYEES_DATABASE_ID=

# URL o ID de la página raíz de Notion donde el bot crea sus páginas y BDs
NOTION_PARENT_PAGE_ID=https://app.notion.com/p/...

# Nombre de la BD de usuarios web en Notion (no cambiar salvo que la renombres en Notion)
NOTION_USERS_DATABASE_NAME=Usuarios web

# ─────────────────────────────────────────────
# IA (Anthropic / Claude)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─────────────────────────────────────────────
# EMAIL (para recuperación de contraseña)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucuenta@igeneris.com
SMTP_PASSWORD=
SMTP_FROM=tucuenta@igeneris.com
SMTP_USE_TLS=true
